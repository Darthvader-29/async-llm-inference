# =============================================================================
# Asynchronous AI Serving Engine — environment configuration.
#
# Copy to `.env` (the stack runs out of the box with these defaults):
#   POSIX : cp .env.example .env
#   PWSH  : Copy-Item .env.example .env
#
# `docker compose` auto-loads `.env` from the project directory for ${VAR}
# interpolation. The same AIE_* names also configure a host-run dev process
# (`uv run poe api` / `uv run poe worker`) via pydantic-settings
# (env_prefix="AIE_", nested groups use the "__" delimiter).
#
# Defaults are local-only and safe to commit. NEVER commit a filled-in .env with
# real secrets — it is git-ignored and .dockerignore'd.
# =============================================================================

# --- Runtime environment -----------------------------------------------------
# dev | test | prod. Anything != prod triggers the zero-cloud MinIO redirect in
# Settings WHEN no object-store endpoint is set. In compose we set the endpoint
# explicitly (to http://minio:9000), so the redirect is effectively pre-satisfied.
AIE_ENV=dev

# --- API authentication ------------------------------------------------------
# Comma-separated API keys accepted on the X-API-Key header. CHANGE for anything
# beyond local. scripts/smoke.ps1 and the README quickstart use the FIRST key.
AIE_API_KEYS=local-dev-key

# --- PostgreSQL --------------------------------------------------------------
# These three feed BOTH the postgres container AND the app's AIE_DATABASE_URL
# (assembled in compose). For a HOST-run process, set AIE_DATABASE_URL directly.
AIE_POSTGRES_USER=aie
AIE_POSTGRES_PASSWORD=aie
AIE_POSTGRES_DB=aie
# Host-run override (compose sets its own, pointing at the `postgres` service):
#   AIE_DATABASE_URL=postgresql+asyncpg://aie:aie@localhost:5432/aie

# --- Redis -------------------------------------------------------------------
# Compose sets AIE_REDIS_URL=redis://redis:6379/0 for containers. Host-run default:
#   AIE_REDIS_URL=redis://localhost:6379/0

# --- Object store (MinIO / S3-compatible) ------------------------------------
# These credentials become BOTH the MinIO root user/password AND the S3
# access/secret keys the app uses (one source of truth).
AIE_OBJECT_STORE__ACCESS_KEY_ID=minioadmin
AIE_OBJECT_STORE__SECRET_ACCESS_KEY=minioadmin
AIE_OBJECT_STORE__BUCKET=aie-artifacts
AIE_OBJECT_STORE__REGION=us-east-1
#
# ENDPOINT resolution (the single most common containerization gotcha):
#  - IN CONTAINERS, compose sets AIE_OBJECT_STORE__ENDPOINT_URL=http://minio:9000
#    automatically (service name, NOT localhost). Do not set it here.
#  - ON HOST (`uv run poe api`), leave it UNSET: with AIE_ENV != prod the Settings
#    validator auto-fills http://localhost:9000 (path-style) for you.
#    To point a host process elsewhere, set it explicitly:
#      AIE_OBJECT_STORE__ENDPOINT_URL=http://localhost:9000

# --- Broker / Redis Streams (Settings defaults; override only if needed) ------
# AIE_BROKER__STREAM=aie:jobs
# AIE_BROKER__GROUP=aie-workers
# AIE_BROKER__DLQ=aie:jobs:dlq
# AIE_BROKER__MAX_ATTEMPTS=3
# AIE_BROKER__BLOCK_MS=5000
# AIE_BROKER__RECLAIM_IDLE_MS=60000
# AIE_BROKER__WORKER_CONCURRENCY=8

# --- Concurrency / retry (Settings defaults; override only if needed) ---------
# AIE_OFFLOAD_MAX_WORKERS=32
# AIE_RETRY__MAX_ATTEMPTS=3
# AIE_RETRY__BASE_DELAY_S=0.2
# AIE_RETRY__MAX_DELAY_S=10.0

# =============================================================================
# REAL PROVIDER KEYS — LEAVE COMMENTED to use deterministic FAKE providers
# (zero keys, zero cloud). Uncomment + fill to activate the real SDK adapters.
# =============================================================================
# AIE_HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AIE_PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AIE_PROVIDERS__PINECONE_INDEX=aie-index
#
# For a REAL AWS S3 (instead of MinIO): set AIE_ENV=prod AND provide real keys +
# region (omit the endpoint to hit AWS). The zero-cloud redirect ONLY engages
# when AIE_ENV != prod.
# AIE_ENV=prod
# AIE_OBJECT_STORE__ENDPOINT_URL=
# AIE_OBJECT_STORE__ACCESS_KEY_ID=AKIA....
# AIE_OBJECT_STORE__SECRET_ACCESS_KEY=....
# AIE_OBJECT_STORE__REGION=us-east-1
